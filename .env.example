# ==============================================================================
# QuillSync Environment Variables Template
# ==============================================================================
# Instructions:
# 1. Duplicate this file and rename it to `.env` in the root of the project.
# 2. Replace the placeholder values with your actual local or production secrets.
# 3. DO NOT commit your actual `.env` file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Server Configuration
# ------------------------------------------------------------------------------
# The port on which the backend Node.js (Express) server will run.
PORT=5000

# The environment the application is running in (development, test, production).
NODE_ENV=development

# ------------------------------------------------------------------------------
# Database Configuration (MongoDB)
# ------------------------------------------------------------------------------
# The connection string for the MongoDB database. 
# For local development: mongodb://localhost:27017/quillsync
MONGODB_URI=mongodb://localhost:27017/quillsync

# ------------------------------------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------------------------------------
# Secret key used to sign access tokens for secure API communication.
# Generate a strong key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# Expiration time for the access token (e.g., 15m, 1h).
JWT_EXPIRES_IN=1h

# Secret key used to sign refresh tokens. Must be different from JWT_SECRET.
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_here

# Expiration time for the refresh token (e.g., 7d, 30d).
REFRESH_TOKEN_EXPIRES_IN=7d

# ------------------------------------------------------------------------------
# Client / Frontend Configuration
# ------------------------------------------------------------------------------
# The URL where the frontend React application is hosted. 
# Used for CORS policy in Express and generating links.
# For local development: http://localhost:3000
CLIENT_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Real-Time Collaboration (Socket.IO)
# ------------------------------------------------------------------------------
# The origins allowed to connect to the WebSocket server for real-time document
# editing, live cursors, and presence indicators.
SOCKET_CORS_ORIGIN=http://localhost:3000

# ------------------------------------------------------------------------------
# File Storage & Attachments (AWS S3)
# ------------------------------------------------------------------------------
# Configuration for storing rich document attachments, inline images, etc.
# AWS IAM user access key ID with S3 permissions.
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here

# AWS IAM user secret access key.
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# The AWS region where your S3 bucket is hosted (e.g., us-east-1).
AWS_REGION=us-east-1

# The name of the S3 bucket where files will be uploaded.
AWS_BUCKET_NAME=quillsync-uploads-bucket